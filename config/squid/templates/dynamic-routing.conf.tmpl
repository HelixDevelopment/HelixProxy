# --- external_acl helper: per-request route + health lookup from Redis -------
# ttl=0 negative_ttl=0  => re-evaluated on EVERY request, so a Redis up/down
# flip takes effect on the very next request with NO reconfigure (§4 step 5).
# `concurrency=N` MAY be appended by the compiler if the helper speaks the
# concurrency channel-id protocol (see templates/README.md); omitted = serial.
external_acl_type vpn_route ttl=0 negative_ttl=0 %>ha{Host} {{ACL_HELPER_PATH}}

# Matches when the helper returns `OK` (the tunnel for this request's Host is up).
acl tun_up external vpn_route

# --- per-tunnel egress: route through the gluetun container's parent proxy ---
# REPEAT this pair once per tunnel (the compiler renders N of these).
cache_peer {{PEER_HOST}} parent {{PEER_PORT}} 0 no-query name={{TUNNEL_NAME}}
cache_peer_access {{TUNNEL_NAME}} allow tun_up
cache_peer_access {{TUNNEL_NAME}} deny all

# --- fail-closed: never egress directly; serve a branded 503 when down -------
# `never_direct allow all` forces EVERY request through a cache_peer. When the
# helper returns ERR (tunnel down / Redis stale / no route) no peer is allowed,
# so there is NO direct path that could leak — and the deny below returns the
# branded ERR_TUNNEL_DOWN page (HTTP 503) instead (docs/DYNAMIC_ROUTING.md §5).
# NOTE TO COMPILER: this `http_access deny !tun_up` MUST be inserted BEFORE the
# base squid.conf `http_access allow localnet` line for the deny to be reached
# (Squid evaluates http_access top-to-bottom, first match wins). See README.
never_direct allow all
http_access deny !tun_up
deny_info 503:ERR_TUNNEL_DOWN tun_up
