# --- auth scheme: HTTP Basic against the operator htpasswd (NCSA format) ------
# Basic is paired with HTTPS/CONNECT so credentials are not sent in clear on the
# wire end-to-end; switch `basic` -> `digest` (auth_param digest) if challenge-
# response hashing on the proxy hop is required. The htpasswd file is created by
# the operator with `htpasswd -B` (bcrypt) — hashes only, never plaintext, and
# the file is gitignored (config/htpasswd). casesensitive off => usernames are
# matched case-insensitively; children 5 => up to 5 helper processes.
auth_param basic program /usr/lib/squid/basic_ncsa_auth {{HTPASSWD_PATH}}
auth_param basic children 5
auth_param basic realm {{AUTH_REALM}}
auth_param basic credentialsttl 2 hours
auth_param basic casesensitive off

# --- the gate: a request must carry valid proxy credentials -------------------
acl authed proxy_auth REQUIRED

# --- fail-closed wiring: unauthenticated => 407 Proxy Authentication Required --
# `http_access deny !authed` returns the 407 challenge to any client that has
# not authenticated; the compiler inserts it ABOVE the base allow rules so it is
# reached first. Authenticated clients fall through to the base
# `http_access allow localnet` / `allow localhost` (and, when dynamic routing is
# active, the `deny !tun_up` guard). This composable deny-form lets auth be
# enabled independently of dynamic routing.
http_access deny !authed

# Single-rule alternative (use INSTEAD of the deny above when auth fully REPLACES
# the IP-based localnet policy — i.e. any authenticated user from any source is
# allowed). Leave commented unless that is the intended policy:
#   http_access allow authed
#   http_access deny all
