# =============================================================================
# .env.example — Let's Encrypt hermetic stack (VARIABLE NAMES ONLY)
# =============================================================================
# Copy to `.env` (GITIGNORED — see .gitignore) and fill in for your topology.
# This file is TRACKED and MUST contain NO secret values (§11.4.10 / §11.4.30).
# The DNS-provider API TOKEN is NEVER here — it is a Podman SECRET referenced by
# NAME only (ACME_DNS_TOKEN_SECRET_NAME). The HERMETIC challtestsrv path needs
# NO token at all. Non-secret defaults (URLs, ports, hostnames, provider name)
# are shown as illustrative comments.
#
# Consumed by compose.hermetic.yml + Caddyfile (both env-parameterized).
# =============================================================================

# ---- ACME endpoint ----------------------------------------------------------
# ACME directory URL. Hermetic-first default = local Pebble; the conductor flips
# to LE staging, then production, as a gated cutover (design §7.1).
#   hermetic : https://pebble:14000/dir
#   staging  : https://acme-staging-v02.api.letsencrypt.org/directory
#   prod     : https://acme-v02.api.letsencrypt.org/directory
ACME_DIRECTORY_URL=https://pebble:14000/dir

# Trust anchor for the ACME SERVER endpoint's OWN TLS cert (CA #1 — NOT the
# issued leaf). Hermetic Pebble only: path to the mounted PUBLIC test CA
# pebble.minica.pem. MUST be empty/commented for real LE (public roots trusted).
ACME_CA_ROOT=/run/pebble-ca/pebble.minica.pem

# ACME account contact email (LE expiry notices; Pebble ignores it).
ACME_EMAIL=hermetic@proxy.hermetic.test

# ---- DNS-01 challenge --------------------------------------------------------
# DNS provider MODULE selector (built into CADDY_IMAGE via xcaddy).
#   hermetic : challtestsrv   (this repo's dns.providers.challtestsrv module —
#              writes TXT to the pebble-challtestsrv mgmt API; NO token)
#   real     : cloudflare | route53 | ovh | ... (operator's caddy-dns provider)
ACME_DNS_PROVIDER=challtestsrv

# Hermetic-only: pebble-challtestsrv management API base URL the DNS module POSTs
# set-txt/clear-txt to (unauthenticated, pod-internal). Not used for real providers.
CHALLTESTSRV_MGMT_URL=http://challtestsrv:8055

# Caddy's OWN pre-issue propagation self-check resolver — MUST be the same mock
# DNS server the CA queries, or Caddy stalls (ANALYSIS.md Q6 gotcha #3).
ACME_RESOLVERS=challtestsrv:8053
ACME_PROPAGATION_DELAY=2s
ACME_PROPAGATION_TIMEOUT=30s

# ---- DNS-provider secret (REAL provider path ONLY — NOT needed for hermetic) --
# CANONICAL Podman secret NAME (reconciled 2026-07-01): helixproxy_caddy_dns_token
# — matches the existing helixproxy_api_* secret family (tls.go) + design doc.
# NAME ONLY, NEVER the value (§11.4.10). Provisioned OUT OF BAND by the operator:
#   podman secret create helixproxy_caddy_dns_token <token-file>
# Leave UNUSED / secret uncreated for the hermetic challtestsrv path.
ACME_DNS_TOKEN_SECRET_NAME=helixproxy_caddy_dns_token

# Mount PATH of the above secret inside the Caddy container. Caddy reads the
# token VALUE from this file at runtime ({file.<path>}) — the value never touches
# env/compose/git. Must match the secret NAME under /run/secrets. Real path only.
ACME_DNS_TOKEN_FILE=/run/secrets/helixproxy_caddy_dns_token

# ---- Caddy admin API --------------------------------------------------------
# OFF by default (no admin surface). The Phase-5 rotation test sets this to an
# address (0.0.0.0:2019) to force a renewal via POST /load (ANALYSIS.md Q4).
CADDY_ADMIN=off
# Force-renewal ratio for the rotation test (leave empty except during Phase 5).
# CADDY_RENEWAL_RATIO=1

# ---- Site + upstream --------------------------------------------------------
# Test hostname the cert is FOR (design Decision A). Hermetic default:
TEST_HOSTNAME=proxy.hermetic.test

# Plaintext, pod-internal upstream Caddy reverse-proxies to (design §4.3).
# Reached by service NAME on the shared network, e.g. admin:80
CADDY_UPSTREAM=admin:80

# ---- Ports (ALL HIGH, >1024 — rootless Podman; design §4.4) -----------------
# Caddy host-published ports (container listens 443/80 internally).
CADDY_HTTPS_PORT=8443
CADDY_HTTP_PORT=8080
# Pebble host-published ports (loopback-bound; ACME dir + per-run CA fetch).
PEBBLE_DIR_PORT=14000
PEBBLE_MGMT_PORT=15000
# pebble-challtestsrv management API host port (loopback-bound).
CHALLTESTSRV_MGMT_PORT=8055

# ---- Container images + build (PINNED; §11.4.6 — confirm/pin @sha256 at boot) -
# Caddy build version (xcaddy target + base image tag; Dockerfile.caddy/build.sh).
CADDY_VERSION=2.8.4
# Custom xcaddy image WITH the challtestsrv DNS module (emitted by ./build.sh).
CADDY_IMAGE=localhost/helix_proxy/caddy-challtestsrv:2.8.4
# Pebble + challtestsrv images (LE images live on GHCR; pin the digest at boot).
PEBBLE_IMAGE=ghcr.io/letsencrypt/pebble:2.6.0
CHALLTESTSRV_IMAGE=ghcr.io/letsencrypt/pebble-challtestsrv:2.6.0
